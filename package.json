{
  "name": "@isbl/ts-utils",
  "version": "1.0.1",
  "description": "Useful typescript helpers",
  "exports": {
    "types": "./dist/ts-utils.d.mts",
    "default": "./dist/ts-utils.mjs"
  },
  "types": "dist/ts-utils.d.mts",
  "author": "Isabella Skořepová <isabella@skorepova.info>",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@isbl/publisher": "^0.7.1",
    "tsdown": "^0.22.3",
    "typescript": "^4.4.2"
  },
  "scripts": {
    "prepare": "tsdown src/ts-utils.ts --format esm --dts --out-dir dist",
    "prepublishOnly": "isbl-publisher prepublishOnly",
    "publish:npm": "isbl-publisher publish --no-draft"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeWitchBella/isbl-ts-utils.git"
  },
  "type": "module",
  "engines": {
    "node": "^14.13.1 || >=16.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  }
}
